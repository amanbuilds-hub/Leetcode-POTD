class Solution {
    private List<String> result = new ArrayList<>();
    
    public String getHappyString(int n, int k) {
        backtrack(n, new StringBuilder());
        return result.size() >= k ? result.get(k - 1) : "";
    }
    
    private void backtrack(int n, StringBuilder current) {
        // Base case: length n ho gayi
        if (current.length() == n) {
            result.add(current.toString());
            return;
        }
        
        for (char ch : new char[]{'a', 'b', 'c'}) {
            // Adjacent same character nahi honi chahiye
            if (current.length() == 0 || current.charAt(current.length() - 1) != ch) {
                current.append(ch);
                backtrack(n, current);
                current.deleteCharAt(current.length() - 1); // undo
            }
        }
    }
}
