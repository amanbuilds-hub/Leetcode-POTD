class Solution {
    public int[] findThePrefixCommonArray(int[] A, int[] B) {
        int n = A.length;
        int[] c = new int[n];
        HashMap<Integer, Integer> map = new HashMap<>();
        int commonCount = 0;
        for(int i = 0; i<n; i++){
            map.put(A[i], map.getOrDefault(A[i], 0)+1);
            if(map.get(A[i]) == 2){
                commonCount++;
            }

            map.put(B[i], map.getOrDefault(B[i], 0)+ 1);
            if(map.get(B[i]) == 2){
                commonCount++;
            }
            c[i] = commonCount;
        }
        return c;
    }
}
