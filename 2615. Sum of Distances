class Solution {
    public long[] distance(int[] nums) {
        int n = nums.length;
        long[] res = new long[n];
        for(int i = 0; i< n; i++){
            int resEle = 0;
            for(int j = 0; j< n ; j++){
                if(i != j) {
                    if(nums[i] == nums[j]){
                        resEle += Math.abs(i - j); 
                    }
                }else continue;
            }
            res[i] = resEle;
        }
        return res;
    }
}



